# Optimized environment configuration for voice latency optimization
# Host-mode URLs for minimal network overhead

FUNASR_BASE_URL=http://127.0.0.1:10095
COSYVOICE_BASE_URL=http://127.0.0.1:50000
LLM_BASE_URL=http://127.0.0.1:11434/v1

# Latency budgets
STT_MAX_LATENCY_MS=600
TTS_MAX_LATENCY_MS=200
E2E_MAX_LATENCY_MS=2000

# TTS backend selection
TTS_BACKEND=qwen3-tts
TTS_HEDGE_ENABLED=true
TTS_PRIMARY=qwen3-tts
TTS_FALLBACK=f5-tts
TTS_LAST_RESORT=cosyvoice2

# STT backend selection
STT_BACKEND=paraformer-streaming

# LLM model
LLM_MODEL=qwen3:14b
