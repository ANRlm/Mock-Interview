# ===== LLM 配置 =====
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen3.5:2b
LLM_TIMEOUT_SECONDS=90
LLM_DISABLE_THINKING=true
LLM_DEFAULT_PROFILE=local

# 可按任务指定模型/档位（为空则继承当前 runtime 配置）
LLM_RESUME_PROFILE=
LLM_RESUME_MODEL=
LLM_INTERVIEW_PROFILE=
LLM_INTERVIEW_MODEL=
LLM_EVALUATION_PROFILE=
LLM_EVALUATION_MODEL=
LLM_VERIFIER_PROFILE=
LLM_VERIFIER_MODEL=
# 路由策略: low_latency / balanced / quality
LLM_ROUTING_STRATEGY=balanced

# ===== 云端 LLM 配置（可选） =====
# 启用后可在 Web 端实时切换到 cloud profile
CLOUD_LLM_ENABLED=false
CLOUD_LLM_BASE_URL=
CLOUD_LLM_API_KEY=
CLOUD_LLM_MODEL=
CLOUD_LLM_TIMEOUT_SECONDS=90
CLOUD_LLM_DISABLE_THINKING=false

# ===== STT 配置 =====
STT_BACKEND=funasr-http
FUNASR_BASE_URL=http://127.0.0.1:10095
FUNASR_HEALTH_PATH=/healthz
FUNASR_TIMEOUT_SECONDS=20
FUNASR_USE_ITN=true
FUNASR_EXTRA_PAYLOAD={}

# ===== TTS 配置 =====
TTS_BACKEND=cosyvoice2-http
COSYVOICE_BASE_URL=http://127.0.0.1:50000
# 固定使用 CosyVoice FastAPI 的 /inference_sft 表单接口
COSYVOICE_TTS_PATH=/inference_sft
COSYVOICE_HEALTH_PATH=/openapi.json
COSYVOICE_TIMEOUT_SECONDS=25
COSYVOICE_VOICE=default_zh
COSYVOICE_MODE=sft
COSYVOICE_INSTRUCT_TEXT=用甜美、温柔、自然、清晰的中文女声播报，语气亲切，节奏流畅。
COSYVOICE_SAMPLE_RATE=22050
# 可透传 CosyVoice API 参数，例如: {"speed": 1.1}
COSYVOICE_EXTRA_PAYLOAD={}
COSYVOICE_SPEED=1.6
COSYVOICE_SEED=3407
COSYVOICE_WARM_TIMEOUT_SECONDS=1.2
COSYVOICE_WARM_KEEPALIVE_SECONDS=90
TTS_LEXICON_PATH=./knowledge_base/tts_lexicon.json
TTS_ENABLE_EN_TO_ZH=true
TTS_ENABLE_MARKDOWN_CLEAN=true
TTS_ENABLE_AUTO_PUNCTUATION=true
TTS_SENTENCE_MAX_CHARS=120
TTS_SENTENCE_SOFT_CHARS=64
TTS_REQUEST_TIMEOUT_SECONDS=20
TTS_FIRST_CHUNK_TIMEOUT_SECONDS=6.5
TTS_HEDGE_ENABLED=true
TTS_HEDGE_DELAY_SECONDS=0.85
TTS_HEDGE_MAX_RACERS=2
TTS_CACHE_DIR=./uploads/tts_cache

# ===== 数据库 =====
DATABASE_URL=sqlite+aiosqlite:///./mock_interview.db

# ===== 应用配置 =====
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ALL=true
UPLOAD_DIR=./uploads
CHROMA_DB_DIR=./chroma_db
KNOWLEDGE_BASE_DIR=./knowledge_base
VISION_SAMPLE_INTERVAL=5

# ===== Embedding =====
EMBEDDING_MODEL=BAAI/bge-m3
