# ===== LLM 配置 =====
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen3.5:2b
LLM_TIMEOUT_SECONDS=90
LLM_DISABLE_THINKING=true
LLM_DEFAULT_PROFILE=local

# 可按任务指定模型/档位（为空则继承当前 runtime 配置）
LLM_RESUME_PROFILE=
LLM_RESUME_MODEL=
LLM_INTERVIEW_PROFILE=
LLM_INTERVIEW_MODEL=
LLM_EVALUATION_PROFILE=
LLM_EVALUATION_MODEL=
LLM_VERIFIER_PROFILE=
LLM_VERIFIER_MODEL=

# ===== 云端 LLM 配置（可选） =====
# 启用后可在 Web 端实时切换到 cloud profile
CLOUD_LLM_ENABLED=false
CLOUD_LLM_BASE_URL=
CLOUD_LLM_API_KEY=
CLOUD_LLM_MODEL=
CLOUD_LLM_TIMEOUT_SECONDS=90
CLOUD_LLM_DISABLE_THINKING=false

# ===== STT 配置 =====
STT_BACKEND=funasr-http
FUNASR_BASE_URL=http://127.0.0.1:10095
FUNASR_HEALTH_PATH=/healthz
FUNASR_TIMEOUT_SECONDS=20
FUNASR_USE_ITN=true
FUNASR_EXTRA_PAYLOAD={}

# ===== TTS 配置 =====
TTS_BACKEND=cosyvoice2-http
COSYVOICE_BASE_URL=http://127.0.0.1:50000
# 固定使用 CosyVoice FastAPI 的 /inference_sft 表单接口
COSYVOICE_TTS_PATH=/inference_sft
COSYVOICE_HEALTH_PATH=/openapi.json
COSYVOICE_TIMEOUT_SECONDS=25
COSYVOICE_VOICE=default_zh
COSYVOICE_SAMPLE_RATE=22050
# 可透传 CosyVoice API 参数，例如: {"speed": 1.1}
COSYVOICE_EXTRA_PAYLOAD={}
TTS_CACHE_DIR=./uploads/tts_cache

# ===== 数据库 =====
DATABASE_URL=sqlite+aiosqlite:///./mock_interview.db

# ===== 应用配置 =====
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
UPLOAD_DIR=./uploads
CHROMA_DB_DIR=./chroma_db
KNOWLEDGE_BASE_DIR=./knowledge_base
VISION_SAMPLE_INTERVAL=5

# ===== Embedding =====
EMBEDDING_MODEL=BAAI/bge-m3
